msgstr ""
"Det finns inga skript som är knutna till funktioner som är knutna till den "
"här sökning. Så ingenting händer."

#: fontforgeexe/lookupui.c:4217
#, c-format
msgid "There is no glyph named %s in the font"
msgstr "Det finns ingen glyf med namnet %s i teckensnittet"

#: fontforgeexe/lookupui.c:4237
#, c-format
