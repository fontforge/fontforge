msgstr "Du måste namnge uppslagningen."

#: fontforgeexe/lookupui.c:1804 fontforgeexe/lookupui.c:1810
msgid "Bad feature tag"
msgstr "Tagg för dålig funktion"

#: fontforgeexe/lookupui.c:1804
#, c-format
msgid ""
"The feature tag on line %d (%s) is too long.  It may be at most 4 letters "
"(or it could be a mac feature setting, two numbers in brokets <3,4>)"
msgstr ""
"Funktionstaggen på rad %d (%s) är för lång. Det får vara högst 4 bokstäver "
"(eller så kan det vara en mac-funktionsinställning, två siffror i "
"broschyrerna <3,4>)"

#: fontforgeexe/lookupui.c:1810
#, c-format
msgid "The feature tag on line %d (%s) should be in ASCII.\n"
msgstr "Feature-taggen på rad %d (%s) ska vara i ASCII.\n"

#: fontforgeexe/lookupui.c:1819
#, c-format
