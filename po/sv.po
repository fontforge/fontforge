msgstr "Linjalalternativ"

#: fontforgeexe/problems.cpp:248 fontforgeexe/problems.cpp:592
#: fontforgeexe/problems.cpp:1755
msgid ""
"This reference has been flipped, so the paths in it are drawn backwards"
msgstr "Den här referens har vänts, så vägarna i den är ritade baklänges"

#: fontforgeexe/problems.cpp:267 fontforgeexe/problems.cpp:606
#: fontforgeexe/problems.cpp:1951
msgid "This glyph's advance width is different from the standard width"
msgstr "Den här glyfens avancerade bredd skiljer sig från standardbredden"

#: fontforgeexe/problems.cpp:270 fontforgeexe/problems.cpp:607
#: fontforgeexe/problems.cpp:1960
msgid "This glyph's vertical advance is different from the standard width"
msgstr ""
"Den här glyfens vertikala förskjutning skiljer sig från standardbredden"

#: fontforgeexe/problems.cpp:275 fontforgeexe/problems.cpp:608
#: fontforgeexe/problems.cpp:2078
msgid ""
"This glyph is not mapped to any unicode code point, but its name should be."
msgstr ""
"Den här glyf är inte mappad till någon Unicode-kodpunkt, men dess namn borde"
" vara det."

#: fontforgeexe/problems.cpp:276 fontforgeexe/problems.cpp:611
#: fontforgeexe/problems.cpp:2083
msgid ""
"This glyph is mapped to a unicode code point which is different from its "
"name."
msgstr ""
"Den här glyf är mappad till en Unicode-kodpunkt som skiljer sig från dess "
"namn."

#: fontforgeexe/problems.cpp:285
msgid "Can't fix"
msgstr "Kan inte åtgärdas"

#: fontforgeexe/problems.cpp:285
#, c-format
msgid ""
"The name FontForge would like to assign to this glyph, %.30s, is already "
"used by a different glyph."
msgstr ""
"Det namn som FontForge skulle vilja tilldela den här glyf, %.30s, används "
"redan av en annan glyf."

#: fontforgeexe/problems.cpp:323 fontforgeexe/problems.cpp:593
#: fontforgeexe/problems.cpp:1551
msgid "The selected point is near a vertical stem hint"
msgstr "Den valda punkten är nära en vertikal stam som antyder"

#: fontforgeexe/problems.cpp:323 fontforgeexe/problems.cpp:593
#: fontforgeexe/problems.cpp:1219
msgid "The x coord of the selected point is near the specified value"
msgstr "Den valda punktens x-koordinat ligger nära det angivna värdet"

#: fontforgeexe/problems.cpp:328 fontforgeexe/problems.cpp:609
#: fontforgeexe/problems.cpp:1127
msgid "The selected point is not at integral coordinates"
msgstr "Den valda punkten ligger inte i integrerade koordinater"

#: fontforgeexe/problems.cpp:329 fontforgeexe/problems.cpp:610
#: fontforgeexe/problems.cpp:1129
msgid "The selected point does not have integral control points"
msgstr "Den valda punkten har inte integrerade kontrollpunkter"

#: fontforgeexe/problems.cpp:334 fontforgeexe/problems.cpp:594
#: fontforgeexe/problems.cpp:1551
msgid "The selected point is near a horizontal stem hint"
msgstr "Den valda punkten är nära en horisontell stam som antyder"

#: fontforgeexe/problems.cpp:334 fontforgeexe/problems.cpp:594
#: fontforgeexe/problems.cpp:1244
msgid "The y coord of the selected point is near the specified value"
msgstr "Den valda punktens y-koordinat ligger nära det angivna värdet"

#: fontforgeexe/problems.cpp:335 fontforgeexe/problems.cpp:596
#: fontforgeexe/problems.cpp:1275
msgid "The y coord of the selected point is near the baseline"
msgstr "Den valda punktens y-koordinat ligger nära baslinjen"

#: fontforgeexe/problems.cpp:335 fontforgeexe/problems.cpp:596
#: fontforgeexe/problems.cpp:1278
msgid "The y coord of the selected point is near the xheight"
msgstr "Den valda punktens y-koordinat ligger nära x-höjden"

#: fontforgeexe/problems.cpp:336 fontforgeexe/problems.cpp:597
#: fontforgeexe/problems.cpp:1284
msgid "The y coord of the selected point is near the ascender height"
msgstr "Den valda punktens y-koordinat ligger nära uppstigningshöjden"

#: fontforgeexe/problems.cpp:336 fontforgeexe/problems.cpp:597
#: fontforgeexe/problems.cpp:1281
msgid "The y coord of the selected point is near the cap height"
msgstr "Den valda punktens y-koordinat ligger nära lockets höjd"

#: fontforgeexe/problems.cpp:337 fontforgeexe/problems.cpp:598
#: fontforgeexe/problems.cpp:1287
msgid "The y coord of the selected point is near the descender height"
msgstr "Den valda punktens y-koordinat är nära den nedåtgående höjden"

#: fontforgeexe/problems.cpp:342 fontforgeexe/problems.cpp:605
#: fontforgeexe/problems.cpp:1728
msgid ""
"The selected spline attains its extrema somewhere other than its endpoints"
msgstr ""
"Den valda spline når sitt extrema någon annanstans än i sina ändpunkter"

#: fontforgeexe/problems.cpp:345 fontforgeexe/problems.cpp:599
#: fontforgeexe/problems.cpp:767
msgid "The selected line segment is nearly horizontal"
msgstr "Det valda linjesegmentet är nästan horisontellt"

#: fontforgeexe/problems.cpp:357 fontforgeexe/problems.cpp:600
#: fontforgeexe/problems.cpp:768
msgid "The control point above the selected point is nearly horizontal"
msgstr "Kontrollpunkten ovanför den valda punkten är nästan horisontell"

#: fontforgeexe/problems.cpp:357 fontforgeexe/problems.cpp:600
#: fontforgeexe/problems.cpp:769
msgid "The control point below the selected point is nearly horizontal"
msgstr "Kontrollpunkten under den valda punkten är nästan horisontell"

#: fontforgeexe/problems.cpp:358 fontforgeexe/problems.cpp:601
#: fontforgeexe/problems.cpp:771
