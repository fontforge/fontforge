msgid ""
"Jump Relative On False\n"
"Pops a boolean and an offset\n"
"Changes instruction pointer by offset bytes\n"
"if boolean is false"
msgstr ""

#: fontforgeexe/ttfinstrsui.c:118
msgid ""
"Jump Relative On True\n"
"Pops a boolean and an offset\n"
"Changes instruction pointer by offset bytes\n"
"if boolean is true"
msgstr ""

