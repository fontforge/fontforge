#, c-format
msgid "%1$.30s string for %2$.30s"
msgstr "%2$.30sのための文字列%1$.30s"

#. GT: This is the title for a window showing an outline character
#. GT: It will look something like:
#. GT:  exclam at 33 from Arial
#. GT: $1 is the name of the glyph
#. GT: $2 is the glyph's encoding
#. GT: $3 is the font name
#. GT: $4 is the changed flag ('*' for the changed items)
#, c-format
msgid "%1$.80s at %2$d from %3$.90s%4$s"
msgstr "%3$.90s の %1$.80s (位置: %2$d)%4$s"

#. GT: This is the title for a window showing a bitmap character
#. GT: It will look something like:
#. GT:  exclam at 33 size 12 from Arial
#. GT: $1 is the name of the glyph
#. GT: $2 is the glyph's encoding
#. GT: $3 is the pixel size of the bitmap font
#. GT: $4 is the font name
#, c-format
msgid "%1$.80s at %2$d size %3$d from %4$.80s"
msgstr "%1$.80s (%4$.80s の %2$d 番目, サイズ %3$d)"

#, c-format
msgid "%1$s had a reference, %2$s, with a bad transformation matrix (one of the matrix elements was bigger than 2). I moved the transformed contours into this glyph and made a reference to it, instead."
msgstr "%1$s に、不正な変換行列（行列要素の1つが2より大きい）を持つ参照 %2$s がありました。代わりに、変換された輪郭をこのグリフに移動し、そこへの参照を作成しました。"

#. GT: The user is trying to open a font file which contains multiple fonts and
#. GT: has asked for a font which is not in that file.
#, c-format
msgid "%1$s is not in font file"
msgstr "%1$s はフォントファイルにありません"

#, c-format
msgid "%1$s: %2$d. Expected %3$s got %4$s"
msgstr "%1$s: %2$d. %3$s となるはずが %4$s となっています"

#, c-format
msgid "%d pixel bitmap"
msgstr "%d ピクセル ビットマップ"

#, c-format
msgid "%d pixels"
msgstr "%d ピクセル"

#, c-format
msgid "%d x %d pixels"
msgstr "%d x %d ピクセル"

#, c-format
msgid ""
"%s\n"
"Proceed anyway?"
msgstr ""
"%s\n"
"このまま続行しますか？"

#, c-format
msgid "%s anchor %d"
msgstr "%s アンカー %d"

#. GT: In the next few lines the "%s" is the name of an anchor class, and the
#. GT: rest of the string identifies the type of the anchor
#, c-format
msgid "%s at ligature pos %d"
msgstr "%s 合字位置 %d"

#, c-format
msgid "%s base"
msgstr "%s ベース"

#. GT: There are various broad classes of lookups here and the first string
#. GT: describes those: "Contextual Positioning", Contextual Substitution", etc.
#. GT: Each of those may be formatted in 3 different ways: by (or perhaps using
#. GT: would be a better word) glyphs, classes or coverage tables.
#. GT: So this might look like:
#. GT:  Contextual Positioning by classes
#, c-format
msgid "%s by %s"
msgstr "%2$sによる%1$s"

#, c-format
msgid "%s contextual %d"
msgstr "%s コンテクスチュアル %d"

#, c-format
msgid "%s does not contain an <svg> element at the top"
msgstr "%s の最上位エレメントとして <svg> が含まれていません"

#, c-format
msgid "%s entry"
msgstr "%s 入口"

#, c-format
msgid "%s exit"
msgstr "%s 出口"

#, c-format
msgid "%s had both contours and references, so the contours were moved into this glyph, and a reference to it was added in the original."
msgstr "%s に輪郭と参照の両方が含まれていたため、輪郭をこのグリフに移動し、元のグリフにはこのグリフへの参照を追加しました。"

#, c-format
msgid "%s has a bounding box which is too big for this algorithm to work. Ignored."
msgstr "%s のバウンディングボックスがこのアルゴリズムで処理するには大きすぎるため、無視されました。"

#. GT: This string is used to generate a name for each OpenType lookup.
#. GT: The %s will be filled with the user friendly name of the feature used to invoke the lookup
#. GT: The second %s (if present) is the script
#. GT: While the %d is the index into the lookup list and is used to disambiguate it
#. GT: In case that is needed
#, c-format
msgid "%s in %s lookup %d"
msgstr "%s の %s ルックアップ %d"

#, c-format
msgid "%s is a mac resource file but contains no postscript or truetype fonts"
msgstr "%s はMacリソースファイルですが、PostScript または TrueType フォントを含んでいません"

#, c-format
msgid ""
"%s is not a cidmap file, please download\n"
"http://fontforge.sourceforge.net/cidmaps.tgz"
msgstr ""
"%sはcidmapファイルではありません.\n"
"http://fontforge.sourceforge.net/cidmaps.tgz\n"
"からダウンロードしてください"

