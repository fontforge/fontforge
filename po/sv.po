msgid "A short to be pushed on the stack"
msgstr "En kort som ska läggas på stacken"

#: fontforgeexe/ttfinstrsui.c:493
msgid ""
"A count specifying how many bytes/shorts\n"
"should be pushed on the stack"
msgstr ""
"En räkning som anger hur många byte/kort\n"
"ska läggas på stacken"

#: fontforgeexe/ttfinstrsui.c:496
msgid "An unsigned byte to be pushed on the stack"
msgstr "En osignerad byte som ska skjutas upp på stacken"

