msgstr ""
"Namnet, %.80s, har redan använts för att identifiera en ankarklass i en "
"annan uppslagsdel (%.80s)"

#: fontforgeexe/lookupui.c:2340
msgid "Name used twice"
msgstr "Namnet används två gånger"

#: fontforgeexe/lookupui.c:2340
#, c-format
msgid ""
"The name, %.80s, appears twice in this list.\n"
"Each anchor class must have a distinct name."
msgstr ""
"Namnet %.80s förekommer två gånger i den här förteckning.\n"
"Varje ankarklass måste ha ett distinkt namn."

#: fontforgeexe/lookupui.c:2369
#, c-format
msgid ""
"Do you really want to remove the anchor class, %.80s?\n"
"This will remove all anchor points associated with that class."
msgstr ""
"Vill du verkligen ta bort ankarklassen %.80s?\n"
"Det här kommer att ta bort alla ankarpunkter som är associerade med den klassen."

#: fontforgeexe/lookupui.c:2369
msgid "Remove Anchor Class?"
msgstr "Ta bort Anchor Class?"

#: fontforgeexe/lookupui.c:2516
#, c-format
msgid "Anchor classes in subtable %.80s"
msgstr "Ankarklasser i underskåp %.80s"

#: fontforgeexe/lookupui.c:2587
